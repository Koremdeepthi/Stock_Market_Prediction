import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from datetime import datetime, timedelta
from nltk.sentiment.vader import SentimentIntensityAnalyzer
import unicodedata

# ✅ UPDATED FILE PATH
df_stocks = pd.read_pickle('/Users/Koremdeepthi/Documents/Project Stock predictions/data/pickled_ten_year_filtered_data.pkl')

# Preprocessing
df_stocks['prices'] = df_stocks['adj close'].astype(int)
df_stocks = df_stocks[['prices', 'articles']]
df_stocks['articles'] = df_stocks['articles'].map(lambda x: x.lstrip('.-') if isinstance(x, str) else '')

df = df_stocks[['prices']].copy()

# Add sentiment columns
df["compound"] = 0.0
df["neg"] = 0.0
df["neu"] = 0.0
df["pos"] = 0.0

# Sentiment Analysis
sid = SentimentIntensityAnalyzer()

for date, row in df_stocks.iterrows():
    try:
        sentence = unicodedata.normalize('NFKD', str(row['articles'])).encode('ascii', 'ignore').decode('utf-8')
        ss = sid.polarity_scores(sentence)
        df.at[date, 'compound'] = ss['compound']
        df.at[date, 'neg'] = ss['neg']
        df.at[date, 'neu'] = ss['neu']
        df.at[date, 'pos'] = ss['pos']
    except:
        print(f"Error at {date}")

# Train/Test Split
train_start_date = '2007-01-01'
train_end_date = '2014-12-31'
test_start_date = '2015-01-01'
test_end_date = '2016-12-31'

train = df.loc[train_start_date:train_end_date]
test = df.loc[test_start_date:test_end_date]

# Prepare data
X_train = train[['neg', 'pos']].values
X_test = test[['neg', 'pos']].values
y_train = train['prices']
y_test = test['prices']

# Random Forest Model
from sklearn.ensemble import RandomForestRegressor
rf = RandomForestRegressor()
rf.fit(X_train, y_train)

predictions = rf.predict(X_test)

# Create DataFrame
idx = pd.date_range(test_start_date, test_end_date)
predictions_df = pd.DataFrame(data=predictions, index=idx, columns=['prices'])

# Plot
ax = predictions_df.rename(columns={"prices": "predicted_price"}).plot(title='Random Forest Prediction')
ax.set_xlabel("Dates")
ax.set_ylabel("Stock Prices")
y_test.plot(ax=ax)
plt.show()

# ---------------- OFFSET FUNCTION ----------------
def offset_value(test_start_date, test, predictions_df):
    temp_date = test_start_date
    total_days = 10

    avg_test = 0
    for _ in range(total_days):
        avg_test += test.loc[temp_date, 'prices']
        temp_date = (datetime.strptime(temp_date, "%Y-%m-%d") + timedelta(days=1)).strftime('%Y-%m-%d')
    avg_test /= total_days

    temp_date = test_start_date
    avg_pred = 0
    for _ in range(total_days):
        avg_pred += predictions_df.loc[temp_date, 'prices']
        temp_date = (datetime.strptime(temp_date, "%Y-%m-%d") + timedelta(days=1)).strftime('%Y-%m-%d')
    avg_pred /= total_days

    return avg_test - avg_pred

# Apply offset
diff = offset_value(test_start_date, test, predictions_df)
predictions_df['prices'] += diff

# Smoothing
predictions_df['ewma'] = predictions_df['prices'].ewm(span=60).mean()
predictions_df['actual'] = test['prices']
predictions_df['actual_ewma'] = predictions_df['actual'].ewm(span=60).mean()

# Final Plot
predictions_df[['ewma', 'actual_ewma']].plot(title="Smoothed Prediction vs Actual")
plt.show()

# ---------------- MULTI-YEAR MODEL LOOP ----------------
from sklearn.linear_model import LogisticRegression

years = range(2007, 2017)

for year in years:
    train_start = f'{year}-01-01'
    train_end = f'{year}-10-31'
    test_start = f'{year}-11-01'
    test_end = f'{year}-12-31'

    train = df.loc[train_start:train_end]
    test = df.loc[test_start:test_end]

    X_train = train[['compound', 'neg', 'neu', 'pos']].values
    X_test = test[['compound', 'neg', 'neu', 'pos']].values

    model = LogisticRegression(max_iter=1000)
    model.fit(X_train, train['prices'])

    preds = model.predict(X_test)

    idx = pd.date_range(test_start, test_end)
    pred_df = pd.DataFrame(preds, index=idx, columns=['prices'])

    diff = offset_value(test_start, test, pred_df)
    pred_df['prices'] += diff

    pred_df['ewma'] = pred_df['prices'].ewm(span=10).mean()
    pred_df['actual'] = test['prices']
    pred_df['actual_ewma'] = pred_df['actual'].ewm(span=10).mean()

    pred_df[['ewma', 'actual_ewma']].plot(title=f"{year} Prediction")
    plt.show()

# ---------------- NEURAL NETWORK ----------------
from sklearn.neural_network import MLPClassifier

for year in years:
    train_start = f'{year}-01-01'
    train_end = f'{year}-10-31'
    test_start = f'{year}-11-01'
    test_end = f'{year}-12-31'

    train = df.loc[train_start:train_end]
    test = df.loc[test_start:test_end]

    X_train = train[['compound', 'neg', 'neu', 'pos']].values
    X_test = test[['compound', 'neg', 'neu', 'pos']].values

    mlp = MLPClassifier(hidden_layer_sizes=(100,200,100), max_iter=500)
    mlp.fit(X_train, train['prices'])

    preds = mlp.predict(X_test)

    idx = pd.date_range(test_start, test_end)
    pred_df = pd.DataFrame(preds, index=idx, columns=['prices'])

    diff = offset_value(test_start, test, pred_df)
    pred_df['prices'] += diff

    pred_df['ewma'] = pred_df['prices'].ewm(span=20).mean()
    pred_df['actual'] = test['prices']
    pred_df['actual_ewma'] = pred_df['actual'].ewm(span=20).mean()

    pred_df[['ewma', 'actual_ewma']].plot(title=f"MLP {year}")
    plt.show()
