import numpy as np
import pandas as pd
from nltk.classify import NaiveBayesClassifier
from nltk.corpus import subjectivity
from nltk.sentiment import SentimentAnalyzer
from nltk.sentiment.util import *

# ✅ Updated file path (Dinesh → Koremdeepthi)
df_stocks = pd.read_pickle('/Users/Koremdeepthi/Documents/Project Stock predictions/data/pickled_ten_year_filtered_data.pkl')

df_stocks['prices'] = df_stocks['adj close'].apply(np.int64)

# selecting the prices and articles
df_stocks = df_stocks[['prices', 'articles']]

df_stocks['articles'] = df_stocks['articles'].map(lambda x: x.lstrip('.-'))

df = df_stocks[['prices']].copy()

# Adding new columns
df["compound"] = ''
df["neg"] = ''
df["neu"] = ''
df["pos"] = ''

from nltk.sentiment.vader import SentimentIntensityAnalyzer
import unicodedata

sid = SentimentIntensityAnalyzer()

for date, row in df_stocks.iterrows():
    try:
        sentence = unicodedata.normalize('NFKD', str(row['articles'])).encode('ascii', 'ignore').decode('utf-8')
        ss = sid.polarity_scores(sentence)
        df.at[date, 'compound'] = ss['compound']
        df.at[date, 'neg'] = ss['neg']
        df.at[date, 'neu'] = ss['neu']
        df.at[date, 'pos'] = ss['pos']
    except Exception as e:
        print(f"Error at {date}: {row['articles']}")

# Train-test split
train_start_date = '2007-01-01'
train_end_date = '2014-12-31'
test_start_date = '2015-01-01'
test_end_date = '2016-12-31'

train = df.loc[train_start_date:train_end_date]
test = df.loc[test_start_date:test_end_date]

# Prepare training data
X_train = train[['compound']].astype(float)
y_train = train['prices'].astype(float)

# Model
from sklearn.linear_model import LinearRegression

model = LinearRegression()
model.fit(X_train, y_train)

# Testing
X_test = test[['compound']].astype(float)
y_test = test['prices'].astype(float)

predictions = model.predict(X_test)

# Results
results = pd.DataFrame({
    'Actual': y_test,
    'Predicted': predictions
})

print(results.head())
